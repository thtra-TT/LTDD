<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvOrderTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tên tour"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#1A2A4A" />

        <TextView
            android:id="@+id/tvOrderCustomer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Người đặt: Nguyễn Văn A"
            android:textColor="#444"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/tvOrderPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SĐT: 0900000000"
            android:textColor="#444"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvOrderEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email: abc@gmail.com"
            android:textColor="#444"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvOrderDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ngày đi: 2026-04-12"
            android:textColor="#444"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvOrderStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PENDING"
            android:textStyle="bold"
            android:textColor="#FF9800"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnConfirmOrder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xác nhận"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnCancelOrder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Hủy"
                android:textAllCaps="false" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>