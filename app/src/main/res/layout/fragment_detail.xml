<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F6FF">

    <!-- BOTTOM BAR -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical"
        android:elevation="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GIÁ CHỈ TỪ"
                android:textColor="#9AAAC8"
                android:textSize="10sp"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/tvDetailPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.999.000đ"
                android:textColor="#1148B8"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/ người lớn"
                android:textColor="#B0BCDA"
                android:textSize="11sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnBook"
            android:layout_width="140dp"
            android:layout_height="50dp"
            android:text="Đặt ngay"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_primary_button"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <!-- SCROLL CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomBar"
        android:overScrollMode="never"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HERO MEDIA SLIDER -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vpDetailMedia"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tlMediaIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="10dp"
                    android:background="@android:color/transparent"
                    app:tabIndicatorHeight="0dp"
                    app:tabGravity="center" />

                <ImageView
                    android:id="@+id/ivBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="16dp"
                    android:padding="10dp"
                    android:background="@drawable/bg_circle_white"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="#333" />

                <TextView
                    android:id="@+id/tvDetailBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_search"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="HOT"
                    android:textColor="#E91E63"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- TITLE BLOCK -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="20dp"
                android:elevation="2dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvDetailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tên Tour"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1A2A4A"
                    android:lineSpacingMultiplier="1.2"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="15dp">

                    <TextView
                        android:id="@+id/tvDetailLocation"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="📍 Địa điểm"
                        android:textSize="14sp"
                        android:textColor="#5A7AAF" />

                    <TextView
                        android:id="@+id/tvDetailRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐ 4.9"
                        android:textColor="#1148B8"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDetailReviews"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" (120)"
                        android:textColor="#7A8FAF"
                        android:textSize="14sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F0F4FF" />

                <!-- THỜI GIAN SECTION -->
                <LinearLayout
                    android:id="@+id/llTimeSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="15dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_today"
                        app:tint="#1565C0" />

                    <TextView
                        android:id="@+id/tvTourTimeRange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Khởi hành: Cả năm"
                        android:textColor="#333"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- DETAILS SECTIONS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- MÔ TẢ -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✨ Giới thiệu tour"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="#1148B8"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:id="@+id/tvDetailDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#4A5568"
                            android:textSize="14sp"
                            android:maxLines="6"
                            android:ellipsize="end"
                            android:lineSpacingMultiplier="1.6" />

                        <TextView
                            android:id="@+id/tvReadMore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Xem thêm"
                            android:textColor="#1565C0"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- LỊCH TRÌNH -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🗺️ Lịch trình chi tiết"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="#1148B8"
                            android:layout_marginBottom="15dp" />

                        <LinearLayout
                            android:id="@+id/tvItinerary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- BAO GỒM / KHÔNG BAO GỒM -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="✅ Bao gồm"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:textColor="#2E7D32"
                                android:layout_marginBottom="8dp" />
                            <LinearLayout
                                android:id="@+id/tvIncluded"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="❌ Không có"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:textColor="#C62828"
                                android:layout_marginBottom="8dp" />
                            <LinearLayout
                                android:id="@+id/tvExcluded"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- ĐÁNH GIÁ -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💬 Đánh giá từ du khách"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="#1148B8" />

                            <TextView
                                android:id="@+id/tvReviewScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="4.9 ⭐"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#1148B8" />
                        </RelativeLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="#F6F8FF"
                            android:padding="12dp"
                            android:layout_marginBottom="12dp">

                            <RatingBar
                                android:id="@+id/rbCommentRating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:numStars="5"
                                android:stepSize="0.5" />

                            <EditText
                                android:id="@+id/etCommentContent"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@android:drawable/edit_text"
                                android:minLines="3"
                                android:hint="Chia sẻ trải nghiệm của bạn..."
                                android:textSize="13sp" />

                            <Button
                                android:id="@+id/btnSubmitComment"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="Gửi đánh giá"
                                android:textAllCaps="false"
                                android:backgroundTint="#1148B8"
                                android:textColor="#FFFFFF" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvReviewEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Chưa có đánh giá nào. Hãy là người đầu tiên chia sẻ!"
                            android:textColor="#7A8FAF"
                            android:textSize="13sp"
                            android:visibility="gone"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:id="@+id/llReviews"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</RelativeLayout>