<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F6FF">

    <!-- ══════════════════════════════════════════ -->
    <!-- BOTTOM BAR CỐ ĐỊNH                        -->
    <!-- ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomBarBooking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical"
        android:elevation="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TỔNG CỘNG"
                android:textColor="#9AAAC8"
                android:textSize="10sp"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0đ"
                android:textColor="#1148B8"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnConfirm"
            android:layout_width="150dp"
            android:layout_height="50dp"
            android:text="Thanh toán"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#1565C0"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- ══════════════════════════════════════════ -->
    <!-- SCROLL CONTENT                            -->
    <!-- ══════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomBarBooking"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── PAGE TITLE ──────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:gravity="center_vertical"
                android:elevation="4dp">

                <ImageView
                    android:id="@+id/ivBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="7dp"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="#1148B8"
                    android:layout_marginEnd="12dp"
                    android:background="#11000000" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đặt chuyến đi"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#1A2A4A" />

                    <TextView
                        android:id="@+id/tvBookingTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tên Tour"
                        android:textSize="12sp"
                        android:textColor="#5A7AAF"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="8dp">

                <!-- ── TOUR INFO CARD ───────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:elevation="2dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivBookingImage"
                        android:layout_width="120dp"
                        android:layout_height="100dp"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvBookingTitleCard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Tên Tour"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1A2A4A"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:lineSpacingMultiplier="1.2"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/tvBookingLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍 Địa điểm"
                            android:textSize="13sp"
                            android:textColor="#5A7AAF"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:id="@+id/tvBookingPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0đ / người"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1148B8" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ── SỐ LƯỢNG KHÁCH ──────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:layout_marginBottom="12dp"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số lượng khách"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#1148B8"
                        android:layout_marginBottom="16dp" />

                    <!-- Người lớn -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Người lớn"
                                android:textSize="14sp"
                                android:textColor="#1A2A4A"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Từ 12 tuổi trở lên"
                                android:textSize="11sp"
                                android:textColor="#9AAAC8" />
                        </LinearLayout>

                        <!-- Stepper người lớn -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="#F2F6FF">

                            <TextView
                                android:id="@+id/btnAdultMinus"
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:text="−"
                                android:textSize="20sp"
                                android:textColor="#1565C0"
                                android:gravity="center"
                                android:textStyle="bold"
                                android:background="#FFFFFF"
                                android:elevation="1dp" />

                            <TextView
                                android:id="@+id/edtAdult"
                                android:layout_width="44dp"
                                android:layout_height="38dp"
                                android:text="0"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1A2A4A"
                                android:gravity="center"
                                android:background="#F2F6FF" />

                            <TextView
                                android:id="@+id/btnAdultPlus"
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:text="+"
                                android:textSize="20sp"
                                android:textColor="#FFFFFF"
                                android:gravity="center"
                                android:textStyle="bold"
                                android:background="#1565C0"
                                android:elevation="1dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEF2FA"
                        android:layout_marginBottom="14dp" />

                    <!-- Trẻ em -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Trẻ em"
                                android:textSize="14sp"
                                android:textColor="#1A2A4A"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dưới 12 tuổi · giảm 30%"
                                android:textSize="11sp"
                                android:textColor="#9AAAC8" />
                        </LinearLayout>

                        <!-- Stepper trẻ em -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="#F2F6FF">

                            <TextView
                                android:id="@+id/btnChildMinus"
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:text="−"
                                android:textSize="20sp"
                                android:textColor="#1565C0"
                                android:gravity="center"
                                android:textStyle="bold"
                                android:background="#FFFFFF"
                                android:elevation="1dp" />

                            <TextView
                                android:id="@+id/edtChild"
                                android:layout_width="44dp"
                                android:layout_height="38dp"
                                android:text="0"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1A2A4A"
                                android:gravity="center"
                                android:background="#F2F6FF" />

                            <TextView
                                android:id="@+id/btnChildPlus"
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:text="+"
                                android:textSize="20sp"
                                android:textColor="#FFFFFF"
                                android:gravity="center"
                                android:textStyle="bold"
                                android:background="#1565C0"
                                android:elevation="1dp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <!-- ── CHỌN NGÀY ĐI ────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngày khởi hành"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#1148B8"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvSelectedDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Chạm để chọn ngày đi"
                        android:background="@drawable/bg_input"
                        android:padding="12dp"
                        android:textSize="14sp"
                        android:drawableEnd="@android:drawable/ic_menu_my_calendar"
                        android:gravity="center_vertical" />
                </LinearLayout>

                <!-- ── THÔNG TIN LIÊN HỆ ────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:layout_marginBottom="12dp"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin liên hệ"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#1148B8"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Họ và tên"
                        android:textSize="12sp"
                        android:textColor="#7A8FAF"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/edtName"
                        android:hint="Nhập họ và tên"
                        android:inputType="textPersonName"
                        android:background="@drawable/bg_input"
                        android:padding="12dp"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số điện thoại"
                        android:textSize="12sp"
                        android:textColor="#7A8FAF"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/edtPhone"
                        android:hint="Nhập số điện thoại"
                        android:inputType="phone"
                        android:background="@drawable/bg_input"
                        android:padding="12dp"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textSize="12sp"
                        android:textColor="#7A8FAF"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/edtEmail"
                        android:hint="Nhập email"
                        android:inputType="textEmailAddress"
                        android:background="@drawable/bg_input"
                        android:padding="12dp"
                        android:textSize="14sp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- ── PHƯƠNG THỨC THANH TOÁN ────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:layout_marginBottom="12dp"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phương thức thanh toán"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#1148B8"
                        android:layout_marginBottom="12dp" />

                    <!-- RadioGroup đảm bảo chỉ chọn 1 -->
                    <RadioGroup
                        android:id="@+id/rgPayment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbVNPay"
                            android:text="💳  VNPay"
                            android:checked="true"
                            android:textSize="14sp"
                            android:textColor="#1A2A4A"
                            android:layout_marginBottom="8dp"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="#F2F6FF"
                            android:paddingStart="12dp"
                            android:gravity="center_vertical"
                            android:button="@null"
                            android:drawableEnd="@android:drawable/btn_radio" />

                        <RadioButton
                            android:id="@+id/rbMomo"
                            android:text="💜  Momo"
                            android:textSize="14sp"
                            android:textColor="#1A2A4A"
                            android:layout_marginBottom="8dp"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="#F2F6FF"
                            android:paddingStart="12dp"
                            android:gravity="center_vertical"
                            android:button="@null"
                            android:drawableEnd="@android:drawable/btn_radio" />

                        <RadioButton
                            android:id="@+id/rbCard"
                            android:text="🏦  Thẻ tín dụng"
                            android:textSize="14sp"
                            android:textColor="#1A2A4A"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="#F2F6FF"
                            android:paddingStart="12dp"
                            android:gravity="center_vertical"
                            android:button="@null"
                            android:drawableEnd="@android:drawable/btn_radio" />
                    </RadioGroup>
                </LinearLayout>

                <!-- ── CHI TIẾT GIÁ ─────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:layout_marginBottom="12dp"
                    android:elevation="2dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chi tiết giá"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#1148B8"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvPriceDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Người lớn (0 x 0đ)\nTrẻ em (0 x 0đ)"
                        android:textSize="13sp"
                        android:textColor="#4A5568"
                        android:lineSpacingMultiplier="1.8" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEF2FA"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tổng cộng"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="#1A2A4A" />

                        <TextView
                            android:id="@+id/tvTotalInline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0đ"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#1148B8" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</RelativeLayout>