<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:stateListAnimator="@animator/press_scale"
    android:paddingHorizontal="16dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSettingIcon"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_centerVertical="true"
        app:cardCornerRadius="19dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/profile_accent_soft">
        <ImageView
            android:id="@+id/ivSettingIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="9dp"
            android:src="@drawable/ic_profile_settings"
            app:tint="@color/profile_accent"/>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_toEndOf="@id/cardSettingIcon"
        android:layout_marginStart="14dp"
        android:layout_centerVertical="true">
        <TextView
            android:id="@+id/tvSettingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cài đặt"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/profile_text_primary"/>
        <TextView
            android:id="@+id/tvSettingSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tùy chỉnh giao diện"
            android:textSize="12sp"
            android:textColor="@color/profile_text_secondary"/>
    </LinearLayout>

    <ImageView
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_chevron_right"
        app:tint="@color/profile_text_muted"/>

</RelativeLayout>

