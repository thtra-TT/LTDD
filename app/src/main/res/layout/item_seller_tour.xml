<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="12dp"
    android:background="#FFFFFF">

    <ImageView
        android:id="@+id/ivSellerTourImage"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp">

        <TextView
            android:id="@+id/tvSellerTourTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tên tour"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#1A2A4A" />

        <TextView
            android:id="@+id/tvSellerTourLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Địa điểm"
            android:textColor="#7A8FAF"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvSellerTourPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2.000.000đ"
            android:textColor="#1565C0"
            android:textStyle="bold"
            android:layout_marginTop="6dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnEditTour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sửa"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btnDeleteTour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xóa"
                android:textAllCaps="false"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>