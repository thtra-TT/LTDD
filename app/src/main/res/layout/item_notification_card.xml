<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/profile_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvNotificationStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Mới"
            android:textSize="11sp"
            android:textColor="@color/profile_accent"
            android:background="@color/profile_accent_soft" />

        <TextView
            android:id="@+id/tvNotificationTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Ưu đãi cuối tuần"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/profile_text_primary" />

        <TextView
            android:id="@+id/tvNotificationContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Giảm đến 20% tour biển..."
            android:textSize="13sp"
            android:textColor="@color/profile_text_secondary" />

        <TextView
            android:id="@+id/tvNotificationDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="2026-03-20"
            android:textSize="11sp"
            android:textColor="@color/profile_text_muted" />
    </LinearLayout>
</androidx.cardview.widget.CardView>

